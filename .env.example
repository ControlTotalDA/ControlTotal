# Control Total IoT API — Environment Configuration

APP_NAME="Control Total"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# MySQL (local development)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=control_total
DB_USERNAME=root
DB_PASSWORD=

# PostgreSQL (Railway production — uncomment and set DB_CONNECTION=pgsql)
# DB_CONNECTION=pgsql
# DB_HOST=${{PGHOST}}
# DB_PORT=${{PGPORT}}
# DB_DATABASE=${{PGDATABASE}}
# DB_USERNAME=${{PGUSER}}
# DB_PASSWORD=${{PGPASSWORD}}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# CORS — comma-separated origins (React Native, n8n, web dashboard)
CORS_ALLOWED_ORIGINS=*

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Laravel Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Laravel Reverb (WebSockets)
REVERB_APP_ID=control-total
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Laravel Horizon
HORIZON_PATH=horizon

# Laravel Octane (Railway / production)
OCTANE_SERVER=swoole

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@control-total.io"
MAIL_FROM_NAME="${APP_NAME}"
